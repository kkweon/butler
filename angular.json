{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "libs",
  "projects": {
    "butler": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/butler",
      "sourceRoot": "apps/butler/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/butler",
            "index": "apps/butler/src/index.html",
            "main": "apps/butler/src/main.ts",
            "polyfills": "apps/butler/src/polyfills.ts",
            "tsConfig": "apps/butler/tsconfig.app.json",
            "aot": true,
            "assets": [
              "apps/butler/src/favicon.ico",
              "apps/butler/src/assets",
              "apps/butler/src/manifest.json"
            ],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "apps/butler/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/butler/src/environments/environment.ts",
                  "with": "apps/butler/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "butler:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "butler:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "butler:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "apps/butler/src/test.ts",
            "polyfills": "apps/butler/src/polyfills.ts",
            "tsConfig": "apps/butler/tsconfig.spec.json",
            "karmaConfig": "apps/butler/karma.conf.js",
            "assets": ["apps/butler/src/favicon.ico", "apps/butler/src/assets"],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "apps/butler/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "apps/butler/tsconfig.app.json",
              "apps/butler/tsconfig.spec.json",
              "apps/butler-e2e/tsconfig.json"
            ],
            "exclude": ["**/node_modules/**"]
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "apps/butler-e2e/protractor.conf.js",
            "devServerTarget": "butler:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "butler:serve:production"
            }
          }
        }
      }
    },
    "options": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/options",
      "sourceRoot": "apps/options/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/options",
            "index": "apps/options/src/index.html",
            "main": "apps/options/src/main.ts",
            "polyfills": "apps/options/src/polyfills.ts",
            "tsConfig": "apps/options/tsconfig.app.json",
            "aot": true,
            "assets": [
              "apps/options/src/favicon.ico",
              "apps/options/src/assets"
            ],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "apps/options/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "apps/options/src/environments/environment.ts",
                  "with": "apps/options/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "options:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "options:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "options:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "apps/options/src/test.ts",
            "polyfills": "apps/options/src/polyfills.ts",
            "tsConfig": "apps/options/tsconfig.spec.json",
            "karmaConfig": "apps/options/karma.conf.js",
            "assets": [
              "apps/options/src/favicon.ico",
              "apps/options/src/assets"
            ],
            "styles": [
              "./node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "apps/options/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "apps/options/tsconfig.app.json",
              "apps/options/tsconfig.spec.json",
              "apps/options/e2e/tsconfig.json"
            ],
            "exclude": ["**/node_modules/**"]
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "apps/options/e2e/protractor.conf.js",
            "devServerTarget": "options:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "options:serve:production"
            }
          }
        }
      }
    },
    "chrome-shared-options": {
      "projectType": "library",
      "root": "libs/chrome-shared-options",
      "sourceRoot": "libs/chrome-shared-options/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-ng-packagr:build",
          "options": {
            "tsConfig": "libs/chrome-shared-options/tsconfig.lib.json",
            "project": "libs/chrome-shared-options/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/chrome-shared-options/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "libs/chrome-shared-options/src/test.ts",
            "tsConfig": "libs/chrome-shared-options/tsconfig.spec.json",
            "karmaConfig": "libs/chrome-shared-options/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "libs/chrome-shared-options/tsconfig.lib.json",
              "libs/chrome-shared-options/tsconfig.spec.json"
            ],
            "exclude": ["**/node_modules/**"]
          }
        }
      }
    }
  },
  "defaultProject": "butler"
}
